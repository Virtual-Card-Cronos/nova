# Cronos Network Configuration (Testnet)
NEXT_PUBLIC_CRONOS_RPC=https://evm-t3.cronos.org
NEXT_PUBLIC_CRONOS_TESTNET_RPC=https://evm-t3.cronos.org

# Smart Contract Addresses (Testnet)
POLICY_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_USDC_CONTRACT=0x66e428c3f67a68878562e79A0234c1F83c208770

# Cronos x402 Facilitator Configuration
# Based on: https://github.com/cronos-labs/x402-examples
# Documentation: https://docs.cronos.org/cronos-x402-facilitator/introduction
NEXT_PUBLIC_CRONOS_NETWORK=cronos-testnet
# Options: cronos-mainnet, cronos-testnet

# Gift Up! API Configuration (for gift card fulfillment)
# Get your API key from: https://developer.giftup.com/api#introduction
GIFTUP_API_KEY=your_giftup_api_key_here

# AI Provider Configuration
# Set AI_PROVIDER to 'gemini' or 'openai' (defaults to gemini if GEMINI_API_KEY is set, otherwise openai)
AI_PROVIDER=gemini

# Gemini API Configuration (for Google Gemini)
# Get your API key from: https://aistudio.google.com/app/apikey
# Note: Gemini API uses GOOGLE_API_KEY (GEMINI_API_KEY also supported for convenience)
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here  # Alternative to GOOGLE_API_KEY
GEMINI_MODEL=gemini-2.5-flash

# OpenAI API Configuration (fallback)
OPENAI_API_KEY=your_openai_api_key_here
CRYPTO_AI_MODEL=gpt-4o-mini

# Thirdweb Configuration
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=EXAd9ca24ad80d9f

# Optional: Analytics and Monitoring
NEXT_PUBLIC_ANALYTICS_ID=your_analytics_id_here